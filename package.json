{
  "name": "beaver-designus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n daemon,web \"npm run dev:daemon\" \"npm run dev:web\"",
    "dev:daemon": "tsx watch daemon/cli.ts serve",
    "dev:web": "vite --config web/vite.config.ts",
    "mcp": "tsx daemon/mcp-tools-server.ts",
    "manifest:build": "tsx packages/manifest/src/build.ts",
    "manifest:scaffold-overrides": "tsx packages/manifest/src/scaffold-overrides.ts",
    "preview:wire": "tsx packages/preview-runtime/src/generate-component-map.ts",
    "preview:doctor": "tsx packages/preview-runtime/src/doctor.ts",
    "setup:ds": "node scripts/install-ds.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "framer-motion": "^11.18.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^5.3.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "rehype-highlight": "^7.0.2",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ulid": "^2.3.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.6"
  }
}
